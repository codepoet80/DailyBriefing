{
  "greeting": {
    "name": "Your Name"
  },
  "weather": {
    "latitude": 0.0,
    "longitude": 0.0,
    "units": "fahrenheit"
  },
  "bible": {
    "translation": "ESV",
    "esv_api_key": ""
  },
  "owncloud": {
    "base_url": "https://your-owncloud-host.example.com",
    "username": "your_username",
    "password": "your_password",
    "ssl_verify": false
  },
  "calendars": {
    "mine": [
      {
        "name": "Work",
        "url": "/remote.php/dav/calendars/your_username/calendar-name/?export",
        "writable": true
      },
      {
        "name": "Personal",
        "url": "https://calendar.zoho.com/ical/your-private-token-here",
        "writable": true,
        "default": true,
        "caldav_write_url": "https://caldav.zoho.com/v2/your_account_id/events/your_calendar_uid/",
        "caldav_username": "user@zoho.com",
        "caldav_password": "your-zoho-app-password"
      }
    ],
    "family": [
      { "name": "Nicole", "url": "https://calendar.zoho.com/ical/..." },
      { "name": "Ben",    "url": "https://calendar.google.com/..." }
    ]
  },
  "calendar_filters": {
    "exclude_titles": ["Morning Routine"]
  },
  "news": {
    "importance_threshold": 2,
    "similarity_threshold": 0.65,
    "max_important": 8,
    "max_regular": 20,
    "title_filters": ["coupon", "promo code", "deal of the day"]
  },
  "geek_news": {
    "count": 20
  },
  "podcast": {
    "name": "NPR Up First",
    "feed_url": "https://feeds.npr.org/510318/podcast.xml"
  },
  "unifi": {
    "host": "https://192.168.1.1",
    "username": "your_unifi_username",
    "password": "your_unifi_password",
    "night_start_hour": 22,
    "night_end_hour": 6
  },
  "imessage": {
    "url": "http://192.168.10.3:8080",
    "night_start_hour": 22,
    "night_end_hour": 6,
    "night_end_minute": 30
  },
  "todos": {
    "command": "${HOME}/Projects/library/macos/checkmate.py ls",
    "add_command": "${HOME}/Projects/library/macos/checkmate.py add",
    "count": 8  
  },
  "reading": {
    "papyrus_dir": "~/ownCloud/Dropbox/.papyrus",
    "stagnant_days": 5,
    "max_inactive_days": 30,
    "exclude_titles": []
  },
  "github": {
    "token": "ghp_...",
    "max_count": 30
  },
  "dialectic": {
    "system_prompt": "The user is curious and wants to explore ideas with you. Not everything is a conflict — treat these as shared explorations. Be curious yourself: consider multiple angles, steelman positions you might disagree with, and if the user seems to be taking a side, gently expand, challenge, and probe with them rather than just agreeing. Favor questions and observations over declarations."
  },
  "agent": {
    "enabled": false,
    "anthropic_api_key": "sk-ant-...",
    "model": "claude-haiku-4-5-20251001",
    "pushover_app_token": "YOUR_PUSHOVER_APP_TOKEN",
    "pushover_user_key": "YOUR_PUSHOVER_USER_KEY",
    "pushover_device": "",
    "pushover_sound": ""
  },
  "chat_agent": {
    "enabled": false,
    "model": "claude-sonnet-4-6",
    "shared_secret": "",
    "max_turns_in_context": 20,
    "session_ttl_hours": 24,
    "max_tool_iterations": 8,
    "allowed_tools": [
      "dialectic_save",
      "dialectic_append",
      "dialectic_list",
      "dialectic_get",
      "dialectic_close",
      "dialectic_resume",
      "add_todo",
      "add_calendar_event",
      "send_notification"
    ],
    "system_prompt_extra": ""
  }
}
